---
/**
 * Section heading — bold uppercase with bottom rule (MyCv2 style).
 */
interface Props {
  title: string;
  sub?: boolean;
}
const { title, sub = false } = Astro.props;
---

<h2 class:list={["section-heading", { sub }]}>{title}</h2>

<style>
  .section-heading {
    font-size: var(--fs-11);
    color: var(--color-text);
    font-weight: 700;
    text-transform: uppercase;
    margin: 5mm 0 2mm;
    padding-bottom: 1mm;
    border-bottom: 1pt solid var(--color-text);
    line-height: 1.3;
  }
  .section-heading.sub {
    font-size: var(--fs-10);
    margin: 2mm 0 2mm;
    border-bottom: none;
  }
</style>
