---
/**
 * Further Education / Courses / Seminars.
 * Layout: grid `[year] [name]`, year in orange, name in black.
 */
interface Course {
  year: string | number;
  name: string;
}
interface Props {
  courses: Course[];
}
const { courses } = Astro.props;
---

<ul class="courses">
  {
    courses.map((c) => (
      <li class="course no-break">
        <span class="year">{c.year}</span>
        <span class="name">{c.name}</span>
      </li>
    ))
  }
</ul>

<style>
  .courses {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--fs-10);
    line-height: 1.6;
  }
  .course {
    display: grid;
    grid-template-columns: 12mm 1fr;
    gap: 3mm;
    margin-bottom: 1.2mm;
  }
  .course:last-child {
    margin-bottom: 0;
  }
  .course .year {
    color: var(--color-text-accent);
    font-weight: 700;
  }
  .course .name {
    color: var(--color-text);
  }
</style>
